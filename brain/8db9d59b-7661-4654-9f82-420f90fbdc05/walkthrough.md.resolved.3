    // 3. Thick Black Separator
    setColor(doc, BRAND.accentBlack, 'draw');
    doc.setLineWidth(1.0); // Thick line as per image
    doc.line(M, detailsY + 20, RightX, detailsY + 20);

    return detailsY + 32; 
}

/* ════════════════════════════════════════════════════════════════
     LEAVE REQUEST PDF  —  Two-page A4 corporate document
   ════════════════════════════════════════════════════════════════ */

export interface LeaveRequestPdfData {
    id: string;
    requestNumber?: number;
    employeeName: string;
    employeePosition: string;
    leaveType: string;
    startDate: string;
    endDate: string;
    days: number;
    reason: string;
    submittedDate: string;
    status: string;
    isScattered?: boolean;
    scatteredDates?: string[];
    contactWhileOnLeave?: string;
    handoverLineManager?: string;
    handoverCC?: string;
    handoverDepartment?: string;
    handoverWorkStatus?: string;
    handoverActions?: string;
    handoverRelationships?: string;
    omApprover?: { name: string, signature?: string | null } | null;
    omApprovalDate?: string | null;
    gmApprover?: { name: string, signature?: string | null } | null;
    gmApprovalDate?: string | null;
    rejectionReason?: string;
    approverName?: string;
    approverSignatureDate?: string;
}

export function generateLeaveRequestPdf(req: LeaveRequestPdfData) {
    const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4', compress: true });
    const M = PAGE.marginX;
    const W = PAGE.contentW;

    const isoMonth = new Date(req.submittedDate).toISOString().substring(0,7).replace('-', '');
    const seqText = req.requestNumber ? String(req.requestNumber).padStart(2, '0') : '01';
    const lveId = `ADC-LVE-${isoMonth}-A${seqText}`;

    // --- PAGE 1 ---
    let y = drawHeader(doc, 'LEAVE APPLICATION FORM', lveId, fmtDate(req.submittedDate));

    // Section: Employee Details
    doc.setFont('times', 'bold');
    doc.setFontSize(11);
    setColor(doc, BRAND.black);
    doc.text('1. EMPLOYEE DETAILS', M, y);
    y += 2;
    setColor(doc, BRAND.black, 'draw');
    doc.setLineWidth(0.4);
    doc.line(M, y, PAGE.w - M, y);
    y += 10;

    // Employee Box
    const boxH = 18;
    setColor(doc, BRAND.white, 'fill');
    doc.rect(M, y, W, boxH, 'F');
    doc.setLineWidth(0.2);
    doc.rect(M, y, W, boxH, 'D');

    doc.setFont('times', 'normal');
    doc.setFontSize(9);
    setColor(doc, BRAND.charcoal);
    doc.text('FULL NAME OF APPLICANT', M + 4, y + 6);
    doc.text('POSITION / DESIGNATION', M + (W/2) + 4, y + 6);

    doc.setFont('times', 'bold');
    doc.setFontSize(11);
    setColor(doc, BRAND.black);
    doc.text(req.employeeName.toUpperCase(), M + 4, y + 13);
    doc.text(req.employeePosition.toUpperCase(), M + (W/2) + 4, y + 13);
    y += boxH + 12; // Increased spacing

    // Leave Types & Period
    doc.setFont('times', 'bold');
    doc.setFontSize(11);
    setColor(doc, BRAND.black);
    doc.text('2. LEAVE DETAILS', M, y);
    y += 2;
    doc.line(M, y, PAGE.w - M, y);
    y += 8;

    const thirdW = (W - 8) / 3;
    
    // Leave Type
    setColor(doc, BRAND.white, 'fill');
    doc.rect(M, y, thirdW, boxH, 'F');
    doc.rect(M, y, thirdW, boxH, 'D');
    doc.setFont('times', 'normal'); doc.setFontSize(8.5); doc.text('CATEGORY', M + 4, y + 6);
    doc.setFont('times', 'bold'); doc.setFontSize(10.5); doc.text(req.leaveType.replace(/_/g, ' '), M + 4, y + 13);

    // Period
    setColor(doc, BRAND.white, 'fill');
    const pX = M + thirdW + 4;
    doc.rect(pX, y, thirdW, boxH, 'F');
    doc.rect(pX, y, thirdW, boxH, 'D');
    doc.setFont('times', 'normal'); doc.setFontSize(8.5); doc.text('LEAVE PERIOD', pX + 4, y + 6);
    doc.setFont('times', 'bold'); doc.setFontSize(10); doc.text(`${fmtDate(req.startDate)} — ${fmtDate(req.endDate)}`, pX + 4, y + 13);

    // Days
    const dX = M + (thirdW + 4) * 2;
    setColor(doc, BRAND.white, 'fill');
    doc.rect(dX, y, thirdW, boxH, 'F');
    doc.rect(dX, y, thirdW, boxH, 'D');
    doc.setFont('times', 'normal'); doc.setFontSize(8.5); doc.text('DAYS', dX + 4, y + 6);
    doc.setFont('times', 'bold'); doc.setFontSize(11); doc.text(`${req.days} DAY${req.days !== 1 ? 'S' : ''}`, dX + 4, y + 13);
    
    y += boxH + 12; // Increased spacing

    // Reason
    doc.setFont('times', 'bold');
    doc.setFontSize(10.5);
    doc.text('3. DECLARATION OF REASON', M, y);
    y += 2;
    doc.line(M, y, PAGE.w - M, y);
    y += 6;
    
    const reasonLines = doc.splitTextToSize(req.reason || 'N/A', W - 10);
    const rH = Math.max(14, 6 + reasonLines.length * 5);
    setColor(doc, BRAND.white, 'fill');
    doc.rect(M, y, W, rH, 'F');
    doc.rect(M, y, W, rH, 'D');
    doc.setFont('times', 'normal');
    doc.setFontSize(11);
    doc.text(reasonLines, M + 5, y + 8);
    y += rH + 14; // Increased spacing

    // Contact & Handover
    doc.setFont('times', 'bold');
    doc.setFontSize(11);
    doc.text('4. CONTACT & HANDOVER', M, y);
    y += 2;
    doc.line(M, y, PAGE.w - M, y);
    y += 8;

    const fields = [
        { l: 'CONTACT', v: req.contactWhileOnLeave },
        { l: 'LINE MANAGER', v: req.handoverLineManager },
        { l: 'HANDOVER TO', v: req.handoverCC },
        { l: 'DEPARTMENT', v: req.handoverDepartment },
    ];
    const qW = (W - 12) / 4;
    fields.forEach((f, i) => {
        const fx = M + i * (qW + 4);
        setColor(doc, BRAND.white, 'fill');
        doc.rect(fx, y, qW, 16, 'F');
        doc.rect(fx, y, qW, 16, 'D');
        doc.setFont('times', 'normal'); doc.setFontSize(7.5); doc.text(f.l, fx + 2, y + 5);
        doc.setFont('times', 'bold'); doc.setFontSize(9); doc.text(f.v || '—', fx + 2, y + 11, { maxWidth: qW - 4 });
    });

    drawFooter(doc, 1, 2, 'OFFICIAL DOCUMENT');

    // --- PAGE 2 ---
    doc.addPage();
    y = PAGE.marginY + 15; // Increased top padding

    // Handover Details
    const handoverItems = [
        { label: 'BACKGROUND & WORK STATUS', value: req.handoverWorkStatus },
        { label: 'REQUIRED ACTIONS / FOLLOW UP', value: req.handoverActions },
        { label: 'STAKEHOLDER MANAGEMENT', value: req.handoverRelationships },
    ].filter(h => h.value);

    if (handoverItems.length > 0) {
        doc.setFont('times', 'bold'); doc.setFontSize(11); doc.text('5. HANDOVER REPORT DETAILS', M, y);
        y += 2; doc.line(M, y, PAGE.w - M, y); y += 8;

        handoverItems.forEach(item => {
            const lines = doc.splitTextToSize(item.value!, W - 10);
            const bH = 10 + lines.length * 5;
            setColor(doc, BRAND.white, 'fill');
            doc.rect(M, y, W, bH, 'F');
            setColor(doc, BRAND.lightGray, 'draw');
            doc.rect(M, y, W, bH, 'D');
            
            doc.setFont('times', 'bold'); doc.setFontSize(9); setColor(doc, BRAND.charcoal); doc.text(item.label, M + 4, y + 6);
            doc.setFont('times', 'normal'); doc.setFontSize(11); setColor(doc, BRAND.black); doc.text(lines, M + 4, y + 12);
            y += bH + 8; // Increased gap
        });
    }

    y += 10; // Increased spacing before signatures

    // Authorization
    doc.setFont('times', 'bold'); doc.setFontSize(11); doc.text('6. AUTHORIZATION SIGNATURES', M, y);
    y += 2; doc.line(M, y, PAGE.w - M, y); y += 8;

    const sigLabelW = 40;
    const sigMainW = (W - sigLabelW) / 2;
    const sH = 22;

    // Total Sig Block
    setColor(doc, BRAND.lightGray, 'draw');
    doc.rect(M, y, W, sH * 3);

    // Row 1: OM
    drawSignatureRow(doc, M, y, sigLabelW, sigMainW, W, sH, {
        label: '1. OM',
        labelBg: BRAND.white,
        roleTitle: 'Operations Manager',
        signaturePresent: !!req.omApprovalDate,
        signatureImage: req.omApprover?.signature,
        signatureName: req.omApprover?.name || '',
        date: fmtDate(req.omApprovalDate),
        accentColor: BRAND.black,
        statusIndicator: req.omApprovalDate ? 'APPROVED' : (req.status === 'REJECTED_OM' ? 'REJECTED' : undefined)
    });
    y += sH;

    // Row 2: GM
    drawSignatureRow(doc, M, y, sigLabelW, sigMainW, W, sH, {
        label: '2. GM',
        labelBg: BRAND.white,
        roleTitle: 'General Manager',
        signaturePresent: !!req.gmApprovalDate,
        signatureImage: req.gmApprover?.signature,
        signatureName: req.gmApprover?.name || '',
        date: fmtDate(req.gmApprovalDate),
        accentColor: BRAND.black,
        statusIndicator: req.gmApprovalDate ? 'APPROVED' : (req.status === 'REJECTED_GM' ? 'REJECTED' : undefined)
    });
    y += sH;

    // Row 3: CEO
    const isCeoApproved = req.status === 'APPROVED';
    drawSignatureRow(doc, M, y, sigLabelW, sigMainW, W, sH, {
        label: '3. CEO',
        labelBg: BRAND.white,
        roleTitle: 'Chief Executive Officer',
        signaturePresent: isCeoApproved,
        signatureName: req.approverName || 'CEO',
        date: req.approverSignatureDate || (isCeoApproved ? fmtDate(new Date().toISOString()) : '—'),
        accentColor: BRAND.black,
        statusIndicator: isCeoApproved ? 'APPROVED' : (req.status === 'REJECTED_CEO' ? 'REJECTED' : undefined)
    });

    drawFooter(doc, 2, 2, 'OFFICIAL DOCUMENT');

    const filename = `leave-request-${req.employeeName.replace(/\s+/g, '-')}-${req.id.substring(0, 8)}.pdf`;
    doc.save(filename);
    return filename;
}

interface SignatureRowOpts {
    label: string;
    labelBg: [number, number, number];
    roleTitle: string;
    signaturePresent: boolean;
    signatureImage?: string | null;
    signatureName: string;
    date: string;
    accentColor: [number, number, number];
    statusIndicator?: 'APPROVED' | 'REJECTED';
}

function drawSignatureRow(doc: jsPDF, x: number, y: number, labelW: number, mainW: number, totalW: number, rowH: number, opts: SignatureRowOpts) {
    setColor(doc, BRAND.black, 'draw');
    doc.setLineWidth(0.2);
    doc.rect(x, y, labelW, rowH, 'D');

    doc.setFont('times', 'bold'); doc.setFontSize(8.5); setColor(doc, BRAND.black);
    doc.text(opts.label, x + 4, y + (rowH / 2) + 2);

    const sigX = x + labelW;
    doc.rect(sigX, y, mainW, rowH, 'D');
    doc.setFont('times', 'normal'); doc.setFontSize(7); setColor(doc, BRAND.charcoal);
    doc.text('SIGNATURE', sigX + 2, y + 4);

    if (opts.signaturePresent) {
        if (opts.signatureImage) {
            try {
                const fmt = opts.signatureImage.startsWith('data:image/png') ? 'PNG' : 'JPEG';
                doc.addImage(opts.signatureImage, fmt, sigX + 5, y + 4, 30, 14);
            } catch { doc.text(opts.signatureName, sigX + 5, y + 10); }
        } else {
            doc.setFont('times', 'bolditalic'); doc.setFontSize(10); doc.text(opts.signatureName, sigX + 5, y + 12);
        }
    }

    const dateX = sigX + mainW;
    doc.rect(dateX, y, totalW - labelW - mainW, rowH, 'D');
    doc.text('DATE', dateX + 2, y + 4);
    doc.setFont('times', 'bold'); doc.setFontSize(9); setColor(doc, BRAND.black);
    doc.text(opts.date || '—', dateX + 4, y + 12);

    if (opts.statusIndicator) {
        doc.setFontSize(7);
        doc.text(opts.statusIndicator, dateX + 4, y + 18);
    }
}

export function generateSignatureFormPdf(approverName: string = '', role: string = '') {
    const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4', compress: true });
    drawHeader(doc, 'CONSENT AGREEMENT');
    // ... Simplified mock for now to keep it consistent ...
    doc.save('signature-consent.pdf');
    return 'signature-consent.pdf';
}
