  const [employeeFilter, setEmployeeFilter] = useState<string>("all");
  const [isBulkRejectOpen, setIsBulkRejectOpen] = useState(false);
  const [bulkRejectReason, setBulkRejectReason] = useState("");
  const { toast } = useToast();
  const { user } = useAuth();
  const queryClient = useQueryClient();
  const detailsRef = useRef<HTMLDivElement>(null);

  const getInitials = (name: string) => {
    return name
      .split(" ")
      .map((n) => n[0])
      .join("")
      .toUpperCase()
      .slice(0, 2);
  };

  const fmtDate = (d: string | null | undefined): string => {
    if (!d) return "—";
    return new Date(d).toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
  };

  // Read URL parameters on mount
  useEffect(() => {
    const status = searchParams.get("status");
    if (status) {
      setStatusFilter(status);
    }

    // Auto-open new request dialog when ?new=true is present (e.g. from dashboard)
    const openNew = searchParams.get("new");
    if (openNew === "true") {
      setEditingRequest(null);
      setStartDate("");
      setEndDate("");
      setDescription("");
      setContactWhileOnLeave("");
      setHandoverLineManager("");
      setHandoverCC("");
      setHandoverDepartment(user?.employee?.department || "");
      setHandoverWorkStatus("");
      setHandoverActions("");
      setHandoverRelationships("");
      setEmployeeSignature("");
      setIsScattered(false);
      setScatteredDates([]);
      setIsNewRequestOpen(true);
      // Clear the 'new' param from URL to prevent re-opening on refresh
      const newParams = new URLSearchParams(searchParams);
      newParams.delete("new");
      globalThis.history.replaceState(
        {},
        "",
        `${globalThis.location.pathname}${newParams.toString() ? "?" + newParams.toString() : ""}`,
      );
    }
  }, [searchParams, user?.employee?.department]);

  // New Request Form State
  const [startDate, setStartDate] = useState("");
  const [endDate, setEndDate] = useState("");
  const [leaveType, setLeaveType] = useState<LeaveType>("ANNUAL");
  const [description, setDescription] = useState("");

  // New Fields State
  const [contactWhileOnLeave, setContactWhileOnLeave] = useState("");
  const [handoverLineManager, setHandoverLineManager] = useState("");
  const [handoverCC, setHandoverCC] = useState("");
  const [handoverDepartment, setHandoverDepartment] = useState("");
  const [handoverWorkStatus, setHandoverWorkStatus] = useState("");
  const [handoverActions, setHandoverActions] = useState("");
  const [handoverRelationships, setHandoverRelationships] = useState("");
  const [employeeSignature, setEmployeeSignature] = useState("");
  const [isSubmitting, setIsSubmitting] = useState(false);

  // Scattered leave state
  const [isScattered, setIsScattered] = useState(false);
  const [scatteredDates, setScatteredDates] = useState<string[]>([]);

  // Removed employee selector – employees create requests for themselves
  const handleCreateRequest = async (e?: React.FormEvent) => {
    if (e) e.preventDefault();
    setIsSubmitting(true);
    try {
      const payload = {
        startDate: new Date(startDate).toISOString(),
        endDate: new Date(endDate).toISOString(),
        leaveType,
        description,
        isScattered,
        scatteredDates: isScattered ? scatteredDates : undefined,
        contactWhileOnLeave,
        handoverLineManager,
        handoverCC,
        handoverDepartment,
        handoverNotes: "",
        handoverWorkStatus,
        handoverActions,
        handoverRelationships,
        employeeSignature,
      };

      if (editingRequest) {
        await api.put(`/leave-requests/${editingRequest.id}`, payload);
        toast({
          title: "Success",
          description: "Leave request updated successfully",
        });
      } else {
        await api.post("/leave-requests", payload);
        toast({
          title: "Success",
          description: "Leave request submitted successfully",
        });
      }

      setIsNewRequestOpen(false);
      setEditingRequest(null);
      // Reset form
      setStartDate("");
      setEndDate("");
      setDescription("");
      setContactWhileOnLeave("");
      setHandoverLineManager("");
      setHandoverCC("");
      setHandoverDepartment(user?.employee?.department || "");
      setHandoverWorkStatus("");
      setHandoverActions("");
      setHandoverRelationships("");
      setEmployeeSignature("");
      setIsScattered(false);
      setScatteredDates([]);

      queryClient.invalidateQueries({ queryKey: ["leaveRequests"] });
    } catch (error: unknown) {
      const err = error as { response?: { data?: { message?: string } } };
      toast({
        variant: "destructive",
        title: "Error",
        description:
          err.response?.data?.message ||
          `Failed to ${editingRequest ? "update" : "submit"} request`,
      });
    } finally {
      setIsSubmitting(false);
    }
  };

  const handleEditClick = (request: LeaveRequest) => {
    setEditingRequest(request);
    setStartDate(request.startDate);
    setEndDate(request.endDate);
    setLeaveType(request.leaveType);
    setDescription(request.reason || "");
    setContactWhileOnLeave(request.contactWhileOnLeave || "");
    setHandoverLineManager(request.handoverLineManager || "");
    setHandoverCC(request.handoverCC || "");
    setHandoverDepartment(request.handoverDepartment || "");
    setHandoverWorkStatus(request.handoverWorkStatus || "");
    setHandoverActions(request.handoverActions || "");
    setHandoverRelationships(request.handoverRelationships || "");
    setEmployeeSignature(request.employeeSignature || "");
    setIsScattered(request.isScattered || false);
    setScatteredDates(request.scatteredDates || []);
    setIsNewRequestOpen(true);
  };

  // Approval mutations
  const hodApprove = useMutation({
    mutationFn: (id: string) =>
      api.post(`/leave-requests/${id}/hod-approve`, { comments: "" }),
    onMutate: async (id) => {
      await queryClient.cancelQueries({
        queryKey: ["leaveRequests", currentPage, itemsPerPage],
      });
      const previousData = queryClient.getQueryData([
        "leaveRequests",
        currentPage,
        itemsPerPage,
      ]);

      queryClient.setQueryData(
        ["leaveRequests", currentPage, itemsPerPage],
        (
          old:
            | { success: boolean; data: { leaveRequests: LeaveRequest[] } }
            | undefined,
        ) => {
          if (!old) return old;
          return {
            ...old,
            data: {
              ...old.data,
              leaveRequests: old.data.leaveRequests.map((req: LeaveRequest) =>
                req.id === id
                  ? {
                      ...req,
                      status: "PENDING_GM",
                      omApprovalDate: new Date().toISOString(),
                    }
                  : req,
              ),
            },
          };
        },
      );

      return { previousData };
    },
    onError: (err: unknown, variables, context) => {
      const error = err as { response?: { data?: { message?: string } } };
      queryClient.setQueryData(
        ["leaveRequests", currentPage, itemsPerPage],
        context?.previousData,
      );
      toast({
        variant: "destructive",
        title: "Error",
        description: error.response?.data?.message || "Failed to approve",
      });
    },
    onSettled: () => {
      queryClient.invalidateQueries({ queryKey: ["leaveRequests"] });
    },
    onSuccess: () => {
      toast({
        title: "Success",
        description: "Request approved (HOD Projects)",
      });
    },
  });

  const omApprove = useMutation({
