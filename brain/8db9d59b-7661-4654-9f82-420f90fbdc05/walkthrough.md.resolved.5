                    <Select value={handoverCC} onValueChange={setHandoverCC}>
                      <SelectTrigger className="bg-background/50"><SelectValue placeholder="Colleague" /></SelectTrigger>
                      <SelectContent>
                        {handoverOptions.map((emp: DeptEmployee) => (
                          <SelectItem key={emp.id} value={emp.user?.name || emp.name || emp.id}>{emp.user?.name || emp.name}</SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                  </div>
                  <div className="space-y-2">
                    <Label>Department</Label>
                    <Input value={handoverDepartment} readOnly className="bg-muted/50" />
                  </div>
                </div>
                <div className="grid grid-cols-1 gap-4">
                  <Textarea value={handoverWorkStatus} onChange={(e) => setHandoverWorkStatus(e.target.value)} placeholder="Work status..." className="h-20 bg-background/50 resize-none" />
                  <Textarea value={handoverActions} onChange={(e) => setHandoverActions(e.target.value)} placeholder="Required actions..." className="h-20 bg-background/50 resize-none" />
                  <Textarea value={handoverRelationships} onChange={(e) => setHandoverRelationships(e.target.value)} placeholder="Key contacts..." className="h-20 bg-background/50 resize-none" />
                </div>
              </div>

              <div className="space-y-2 pt-4 border-t border-border/50">
                <Label className="font-semibold">Description / Reason</Label>
                <Textarea value={description} onChange={(e) => setDescription(e.target.value)} placeholder="Reason for leave..." className="h-24 bg-background/50" required />
              </div>
            </div>

            <div className="p-4 sm:p-6 border-t border-border/50 bg-muted/30 flex items-center justify-between gap-4">
              <div className="hidden sm:block">
                {(() => {
                  if (!startDate || !endDate) return null;
                  const ws = user?.employee?.workSchedule || "MON_FRI";
                  const days = isScattered ? calculateLeaveDays(startDate, endDate, ws, scatteredDates) : calculateLeaveDays(startDate, endDate, ws);
                  if (days <= 0) return null;
                  const balanceKey = leaveType.toLowerCase() as keyof typeof user.employee.leaveBalances;
                  const balance = user?.employee?.leaveBalances?.[balanceKey] || 0;
                  const isOver = (leaveType === "ANNUAL" || leaveType === "SICK") && days > balance;
                  return (
                    <div className={cn("text-xs font-medium px-3 py-1.5 rounded-full border", 
                      isOver ? "bg-destructive/10 text-destructive border-destructive/20" : "bg-primary/10 text-primary border-primary/20")}>
                      {isOver ? <span className="flex items-center gap-1.5"><XCircle className="h-3.5 w-3.5" />Balance exceeded</span> : <span>Total: {days} days</span>}
                    </div>
                  );
                })()}
              </div>
              <DialogFooter className="flex-1 sm:flex-initial">
                <Button type="button" variant="ghost" onClick={() => setIsNewRequestOpen(false)}>Cancel</Button>
                <Button type="submit" className="gradient-primary min-w-[140px]" disabled={isSubmitting || (() => {
                  if (!startDate || !endDate) return true;
                  const ws = user?.employee?.workSchedule || "MON_FRI";
                  const days = isScattered ? calculateLeaveDays(startDate, endDate, ws, scatteredDates) : calculateLeaveDays(startDate, endDate, ws);
                  if (days <= 0) return true;
                  if (leaveType === "MATERNITY" && user?.employee?.gender !== "FEMALE") return true;
                  if (leaveType === "PATERNITY" && user?.employee?.gender !== "MALE") return true;
                  if (leaveType !== "ANNUAL" && leaveType !== "SICK") return false;
                  if (!user?.employee?.leaveBalances) return true;
                  const balanceKey = leaveType.toLowerCase() as keyof typeof user.employee.leaveBalances;
                  return days > (user.employee.leaveBalances[balanceKey] || 0);
                })()}>
                  {isSubmitting ? "Submitting..." : (editingRequest ? "Update Request" : "Submit Request")}
                </Button>
              </DialogFooter>
            </div>
          </form>
        </DialogContent>
      </Dialog>

      {/* Bulk Reject Confirmation Dialog */}
      <AlertDialog open={isBulkRejectOpen} onOpenChange={setIsBulkRejectOpen}>
        <AlertDialogContent className="glass border-border/50">
          <AlertDialogHeader>
            <AlertDialogTitle>Reject Selected Requests</AlertDialogTitle>
            <AlertDialogDescription>
              Are you sure you want to reject {selectedRequests.size} selected
