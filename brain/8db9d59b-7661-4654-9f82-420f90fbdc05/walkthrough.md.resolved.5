  // Reuse employees query data for Line Manager / CC dropdowns (avoid duplicate API call)
  const allEmployeesData = employeesData;

  interface DeptEmployee {
    id: string;
    department: string;
    position: string;
    user?: { id: string; name: string };
    name?: string;
  }

  const departmentColleagues: DeptEmployee[] = (allEmployeesData || []).filter(
    (emp: DeptEmployee) =>
      emp.department?.toUpperCase() ===
        user?.employee?.department?.toUpperCase() && emp.user?.id !== user?.id,
  );

  const allColleagues: DeptEmployee[] = (allEmployeesData || []).filter(
    (emp: DeptEmployee) => emp.user?.id !== user?.id,
  );

  const handoverOptions =
    departmentColleagues.length > 0 ? departmentColleagues : allColleagues;

  const { data: paginatedData, isLoading } = useQuery({
    queryKey: ["leaveRequests", currentPage, itemsPerPage, user?.role],
    queryFn: async ({ signal }) => {
      // Non-executives use /my-leaves endpoint, while OM, GM, and CEO use /leave-requests
      const isExecutive = [
        "OPERATIONS_MANAGER",
        "GENERAL_MANAGER",
        "CEO",
      ].includes(user?.role || "");
      const endpoint = isExecutive
        ? "/leave-requests"
        : "/leave-requests/my-leaves";

      const response = await api.get(endpoint, {
        params: isExecutive ? { page: currentPage, limit: itemsPerPage } : {},
        signal, // Pass signal for automatic cancellation
      });
      return response.data;
    },
    enabled: !!user, // Only run query when user is available
  });

  const requests: LeaveRequest[] = useMemo(
    () =>
      paginatedData?.data?.leaveRequests?.map(
        (req: Record<string, unknown>) => ({
          id: req.id as string,
          requestNumber: req.requestNumber as number,
          employeeId: req.employeeId as string,
          employeeName: (req.employee as { user: { name: string } }).user
            .name as string,
          employeePosition: (req.employee as { position: string })
            .position as string,
          employeeAvatar: `https://api.dicebear.com/7.x/initials/svg?seed=${(req.employee as { user: { name: string } }).user.name}&backgroundColor=08033F`,
          leaveType: req.leaveType as LeaveType,
          startDate: req.startDate as string,
          endDate: req.endDate as string,
          days: (() => {
            const ws = "MON_FRI"; // fallback; actual schedule not available here
            const start = (req.startDate as string).split("T")[0];
            const end = (req.endDate as string).split("T")[0];
            if (req.isScattered && req.scatteredDates) {
              // scatteredDates may arrive as a JSON string from the API
              let datesArr: string[] = [];
              if (typeof req.scatteredDates === "string") {
                try { datesArr = JSON.parse(req.scatteredDates as string); } catch { datesArr = []; }
              } else {
                datesArr = req.scatteredDates as string[];
              }
              return datesArr.length;
            }
            return calculateLeaveDays(start, end, ws);
          })(),
          reason: req.description as string,
          status: req.status as LeaveRequest["status"],
          submittedDate: req.createdAt as string,

          // Scattered leave
          isScattered: (req.isScattered as boolean) || false,
          scatteredDates: (() => {
            if (!req.scatteredDates) return [];
            if (typeof req.scatteredDates === "string") {
              try { return JSON.parse(req.scatteredDates as string) as string[]; } catch { return []; }
            }
            return req.scatteredDates as string[];
          })(),

          // Approval details
          omApprover: req.omApprover as
            | { name: string; email: string }
            | undefined,
          omApprovalDate: req.omApprovalDate as string,
          omApprovalComments: req.omApprovalComments as string,
          gmApprover: req.gmApprover as
            | { name: string; email: string }
            | undefined,
          gmApprovalDate: req.gmApprovalDate as string,
          gmApprovalComments: req.gmApprovalComments as string,
          rejectedBy: req.rejectedBy as string,
          rejectedAt: req.rejectedAt as string,
          rejectionReason: req.rejectionReason as string,

          contactWhileOnLeave: req.contactWhileOnLeave as string,
          handoverLineManager: req.handoverLineManager as string,
          handoverCC: req.handoverCC as string,
          handoverDepartment: req.handoverDepartment as string,
          handoverWorkStatus: req.handoverWorkStatus as string,
          handoverActions: req.handoverActions as string,
          handoverRelationships: req.handoverRelationships as string,

          approverName: req.approverName as string,
          approverSignature: req.approverSignature as string,
          approverSignatureDate: req.approverSignatureDate as string,
        }),
      ) || [],
    [paginatedData],
  );

  const openProcessDialog = (
    request: LeaveRequest,
    action: "approved" | "rejected",
  ) => {
    setProcessingRequest(request);
    setProcessAction(action);
    setIsProcessDialogOpen(true);
  };

  const handleProcessRequest = (e: React.FormEvent) => {
    e.preventDefault();
    if (!processingRequest) return;

    if (processAction === "rejected") {
      reject.mutate({
        id: processingRequest.id,
        reason: rejectionReason,
      });
      setIsProcessDialogOpen(false);
      setProcessingRequest(null);
      setRejectionReason("");
    }
  };

  const handleDownloadPDF = async () => {
    if (!selectedRequest) return;

    console.log('[DEBUG] handleDownloadPDF called', { requestId: selectedRequest.id });

    try {
      const filename = generateLeaveRequestPdf({
        id: selectedRequest.id,
        employeeName: selectedRequest.employeeName,
        employeePosition: selectedRequest.employeePosition,
        leaveType: selectedRequest.leaveType,
        startDate: selectedRequest.startDate,
        endDate: selectedRequest.endDate,
        days: selectedRequest.days,
        reason: selectedRequest.reason,
        submittedDate: selectedRequest.submittedDate,
        status: selectedRequest.status,
        isScattered: selectedRequest.isScattered,
        scatteredDates: selectedRequest.scatteredDates,
        contactWhileOnLeave: selectedRequest.contactWhileOnLeave,
        handoverLineManager: selectedRequest.handoverLineManager,
        handoverCC: selectedRequest.handoverCC,
        handoverDepartment: selectedRequest.handoverDepartment,
        handoverWorkStatus: selectedRequest.handoverWorkStatus,
        handoverActions: selectedRequest.handoverActions,
        handoverRelationships: selectedRequest.handoverRelationships,
        omApprover: selectedRequest.omApprover,
        omApprovalDate: selectedRequest.omApprovalDate,
        gmApprover: selectedRequest.gmApprover,
