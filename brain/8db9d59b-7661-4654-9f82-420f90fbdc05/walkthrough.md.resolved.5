                setEditingRequest(null);
                setStartDate("");
                setEndDate("");
                setDescription("");
                setContactWhileOnLeave("");
                setHandoverLineManager("");
                setHandoverCC("");
                setHandoverDepartment(user?.employee?.department || "");
                setHandoverWorkStatus("");
                setHandoverActions("");
                setHandoverRelationships("");
                setEmployeeSignature("");
                setIsNewRequestOpen(true);
