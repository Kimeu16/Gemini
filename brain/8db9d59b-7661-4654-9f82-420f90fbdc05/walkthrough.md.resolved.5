                  </Select>
                  {user?.employee?.leaveBalances && (leaveType === "ANNUAL" || leaveType === "SICK") && (
                    <div className="text-xs text-muted-foreground mt-1 px-1">
                      Available: <span className="font-semibold text-foreground">{user.employee.leaveBalances[leaveType.toLowerCase() as keyof typeof user.employee.leaveBalances]} days</span>
                    </div>
                  )}
                  {leaveType === "MATERNITY" && user?.employee?.gender !== "FEMALE" && (
                    <div className="text-[10px] text-red-500 font-medium mt-1 flex items-center gap-1 px-1">
