              {startDate && endDate && (
                <div className="bg-muted/30 p-3 rounded-md text-sm">
                  <span className="font-semibold">Duration: </span>
                  {(() => {
                    const ws = user?.employee?.workSchedule || "MON_FRI";
                    const days = isScattered && scatteredDates.length > 0
                        ? calculateLeaveDays(startDate, endDate, ws, scatteredDates)
                        : calculateLeaveDays(startDate, endDate, ws);
                    return `${days} day${days === 1 ? "" : "s"}`;
