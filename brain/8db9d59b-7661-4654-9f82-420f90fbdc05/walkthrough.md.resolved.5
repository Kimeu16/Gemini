                            {request.status === "PENDING_OM" &&
                              user?.id === request.employeeId && (
                                <Button
                                  size="sm"
                                  variant="outline"
                                  className="h-9 px-3 border-border/50 hover:bg-accent/50 transition-all duration-200"
