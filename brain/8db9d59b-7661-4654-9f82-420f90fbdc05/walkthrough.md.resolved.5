                  <Input value={contactWhileOnLeave} onChange={(e) => setContactWhileOnLeave(e.target.value)} placeholder="Telephone / Address" className="bg-background/50" />
                </div>
              </div>

              <div className="flex items-center justify-between p-4 rounded-xl border border-primary/10 bg-primary/5">
                <div className="space-y-0.5">
                  <Label className="text-sm font-semibold">Scattered Leave Days</Label>
                  <p className="text-xs text-muted-foreground">Select non-contiguous dates</p>
                </div>
                <button type="button" role="switch" aria-checked={isScattered} onClick={() => { setIsScattered(!isScattered); if (!isScattered) setScatteredDates([]); }}
                  className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${isScattered ? "bg-primary" : "bg-muted"}`}>
                  <span className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${isScattered ? "translate-x-6" : "translate-x-1"}`} />
                </button>
              </div>

              <div className="space-y-4 pt-4 border-t border-border/50">
                <div className="flex items-center gap-2">
                  <div className="h-8 w-1 bg-primary rounded-full" />
