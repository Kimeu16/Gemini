                  <p className="text-xs text-muted-foreground">Click on dates within your range to select/deselect them</p>
                  <div className="flex flex-wrap gap-2">
                    {(() => {
                      const dates: string[] = [];
                      const start = new Date(startDate);
                      const end = new Date(endDate);
                      const current = new Date(start);
                      while (current <= end) {
                        dates.push(current.toISOString().split("T")[0]);
                        current.setDate(current.getDate() + 1);
                      }
                      const startYear = start.getFullYear();
                      const endYear = end.getFullYear();
                      const holidayDetails: { date: string; name: string }[] = [];
                      for (let y = startYear; y <= endYear; y++) {
                        holidayDetails.push(...getKenyanPublicHolidayDetails(y));
                      }
                      return dates.map((dateStr) => {
                        const isSelected = scatteredDates.includes(dateStr);
                        const dateObj = new Date(dateStr + "T00:00:00");
                        const sunday = isSunday(dateStr);
                        const holiday = isKenyanPublicHoliday(dateStr);
                        const saturday = isSaturday(dateStr);
                        const ws = user?.employee?.workSchedule || "MON_FRI";
                        const isBlocked = sunday || holiday || (saturday && ws === "MON_FRI");
                        const holidayInfo = holidayDetails.find(h => h.date === dateStr);
                        if (isBlocked) {
                          return (
                            <div key={dateStr} className="px-3 py-2 rounded-lg text-xs font-medium border bg-muted/50 text-muted-foreground/40 border-border/30 cursor-not-allowed line-through">
                              {dateObj.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" })}
                              {holiday && <span className="block text-[9px] text-red-400 font-normal no-underline">{holidayInfo?.name || "Holiday"}</span>}
                            </div>
                          );
                        }
                        return (
                          <button key={dateStr} type="button" onClick={() => setScatteredDates(prev => prev.includes(dateStr) ? prev.filter(d => d !== dateStr) : [...prev, dateStr].sort())}
                            className={`px-3 py-2 rounded-lg text-xs font-medium border transition-all ${isSelected ? "bg-primary text-white border-primary shadow-sm" : "bg-background border-border hover:border-primary/50"}`}>
                            {dateObj.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" })}
                          </button>
                        );
                      });
                    })()}
                  </div>
                </div>
              )}

