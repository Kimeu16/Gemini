            {user?.role !== "EMPLOYEE" && (
              <Button
                onClick={handleExportAll}
                variant="outline"
                className="gap-2 border-border/50 w-full sm:w-auto"
              >
                <FileSpreadsheet className="h-4 w-4" />
                Export All
