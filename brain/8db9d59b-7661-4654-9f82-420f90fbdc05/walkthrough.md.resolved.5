              </SelectTrigger>
              <SelectContent>
                <SelectItem value="all">All Requests</SelectItem>
                <SelectItem value="PENDING_HOD_PROJECTS">Pending HOD</SelectItem>
                <SelectItem value="PENDING_OM">Pending OM</SelectItem>
                <SelectItem value="PENDING_GM">Pending GM</SelectItem>
                <SelectItem value="APPROVED">Approved</SelectItem>
                <SelectItem value="REJECTED_HOD">Rejected (HOD)</SelectItem>
                <SelectItem value="REJECTED_OM">Rejected (OM)</SelectItem>
                <SelectItem value="REJECTED_GM">Rejected (GM)</SelectItem>
