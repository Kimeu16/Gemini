                {statusFilter !== "all" && (
                  <Badge variant="secondary" className="text-xs">
                    Status: {statusFilter}
                  </Badge>
                )}
                {searchQuery && (
                  <Badge variant="secondary" className="text-xs">
                    Search: {searchQuery}
                  </Badge>
                )}
                {leaveTypeFilter !== "all" && (
                  <Badge variant="secondary" className="text-xs">
                    Type: {leaveTypeFilter}
                  </Badge>
                )}
                {employeeFilter !== "all" && (
                  <Badge variant="secondary" className="text-xs">
                    Employee:{" "}
                    {employeesData?.find(
                      (e: { id: string; user?: { name: string } }) =>
                        e.id === employeeFilter,
                    )?.user?.name || "Selected"}
                  </Badge>
                )}
                {dateFrom && (
                  <Badge variant="secondary" className="text-xs">
                    From: {new Date(dateFrom).toLocaleDateString()}
