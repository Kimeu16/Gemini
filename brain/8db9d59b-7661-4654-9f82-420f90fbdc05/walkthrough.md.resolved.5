            <Card className="glass border-border/50 p-6">
              <h3 className="text-lg font-semibold mb-4">
                My Leave Summary - {new Date().getFullYear()}
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                {(() => {
                  const currentYear = new Date().getFullYear();
                  const yearLeaves = requests.filter((req: LeaveRequest) => {
                    const startYear = new Date(req.startDate).getFullYear();
                    return (
                      startYear === currentYear &&
                      (req.status === "APPROVED" ||
                        req.status === "PENDING_GM" ||
                        req.status === "PENDING_OM")
                    );
                  });

                  // Group by leave type
                  const leaveByType = yearLeaves.reduce(
                    (
                      acc: Record<
                        string,
                        {
                          count: number;
                          days: number;
                          requests: LeaveRequest[];
                        }
                      >,
                      req: LeaveRequest,
                    ) => {
                      if (!acc[req.leaveType]) {
                        acc[req.leaveType] = {
                          count: 0,
                          days: 0,
                          requests: [],
                        };
                      }
                      acc[req.leaveType].count += 1;
                      acc[req.leaveType].days += req.days;
                      acc[req.leaveType].requests.push(req);
                      return acc;
                    },
                    {},
                  );

                  const totalDays: number = Object.values(leaveByType).reduce(
                    (sum: number, type) => sum + type.days,
                    0,
                  );

                  return (
                    <>
                      <div className="p-4 rounded-xl bg-primary/5 border border-primary/20">
                        <p className="text-sm text-muted-foreground mb-1">
