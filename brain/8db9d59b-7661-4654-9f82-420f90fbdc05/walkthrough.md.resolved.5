  // Advanced filtering logic
  const filteredRequests = requests.filter((req: LeaveRequest) => {
    // Status filter
    if (statusFilter !== "all" && req.status !== statusFilter) return false;

    // Search by employee name
    if (
      searchQuery &&
      !req.employeeName.toLowerCase().includes(searchQuery.toLowerCase())
    )
      return false;

    // Leave type filter
    if (leaveTypeFilter !== "all" && req.leaveType !== leaveTypeFilter)
      return false;

    // Employee filter
    if (employeeFilter !== "all" && req.employeeId !== employeeFilter)
      return false;

    // Date range filter
    if (dateFrom && new Date(req.startDate) < new Date(dateFrom)) return false;
    if (dateTo && new Date(req.endDate) > new Date(dateTo)) return false;

    return true;
  });

  return (
    <DashboardLayout>
      <div className="space-y-6">
        <div className="flex flex-col gap-4">
          <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <h1 className="text-2xl sm:text-3xl font-bold">Leave Requests</h1>
              <p className="text-muted-foreground text-sm sm:text-base">
                Manage employee leave applications
              </p>
            </div>
            <Button
              onClick={() => {
                setEditingRequest(null);
                setStartDate("");
                setEndDate("");
                setDescription("");
                setContactWhileOnLeave("");
                setHandoverLineManager("");
                setHandoverCC("");
                setHandoverDepartment(user?.employee?.department || "");
                setHandoverWorkStatus("");
                setHandoverActions("");
                setHandoverRelationships("");
                setEmployeeSignature("");
                setIsNewRequestOpen(true);
              }}
              className="gradient-primary w-full sm:w-auto"
            >
              <Plus className="mr-2 h-4 w-4" /> New Request
            </Button>
          </div>
          <div className="flex flex-wrap items-center gap-2 sm:gap-3">
            <Filter className="h-5 w-5 text-muted-foreground hidden sm:block" />
            <Select value={statusFilter} onValueChange={setStatusFilter}>
              <SelectTrigger className="w-full sm:w-40 glass border-border/50">
                <SelectValue placeholder="Filter by status" />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="all">All Requests</SelectItem>
                <SelectItem value="PENDING_HOD_PROJECTS">Pending HOD</SelectItem>
                <SelectItem value="PENDING_OM">Pending OM</SelectItem>
                <SelectItem value="PENDING_GM">Pending GM</SelectItem>
                <SelectItem value="APPROVED">Approved</SelectItem>
                <SelectItem value="REJECTED_HOD">Rejected (HOD)</SelectItem>
                <SelectItem value="REJECTED_OM">Rejected (OM)</SelectItem>
                <SelectItem value="REJECTED_GM">Rejected (GM)</SelectItem>
              </SelectContent>
            </Select>
            {user?.role !== "EMPLOYEE" && (
              <Button
                onClick={handleExportAll}
                variant="outline"
                className="gap-2 border-border/50 w-full sm:w-auto"
              >
                <FileSpreadsheet className="h-4 w-4" />
                Export All
              </Button>
            )}
          </div>
        </div>

        {/* Year Leave Summary for Employees */}
        {user?.role === "EMPLOYEE" && (
          <motion.div
            initial={{ y: 20, opacity: 0 }}
            animate={{ y: 0, opacity: 1 }}
          >
            <Card className="glass border-border/50 p-6">
              <h3 className="text-lg font-semibold mb-4">
                My Leave Summary - {new Date().getFullYear()}
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                {(() => {
                  const currentYear = new Date().getFullYear();
                  const yearLeaves = requests.filter((req: LeaveRequest) => {
                    const startYear = new Date(req.startDate).getFullYear();
                    return (
                      startYear === currentYear &&
                      (req.status === "APPROVED" ||
                        req.status === "PENDING_GM" ||
                        req.status === "PENDING_OM")
                    );
                  });

                  // Group by leave type
                  const leaveByType = yearLeaves.reduce(
                    (
                      acc: Record<
                        string,
                        {
                          count: number;
                          days: number;
                          requests: LeaveRequest[];
                        }
                      >,
                      req: LeaveRequest,
                    ) => {
                      if (!acc[req.leaveType]) {
                        acc[req.leaveType] = {
                          count: 0,
                          days: 0,
                          requests: [],
                        };
                      }
                      acc[req.leaveType].count += 1;
                      acc[req.leaveType].days += req.days;
                      acc[req.leaveType].requests.push(req);
                      return acc;
                    },
                    {},
                  );

                  const totalDays: number = Object.values(leaveByType).reduce(
                    (sum: number, type) => sum + type.days,
                    0,
                  );

                  return (
                    <>
                      <div className="p-4 rounded-xl bg-primary/5 border border-primary/20">
                        <p className="text-sm text-muted-foreground mb-1">
                          Total Leaves Taken
                        </p>
                        <p className="text-3xl font-bold text-primary">
                          {totalDays}
                        </p>
                        <p className="text-xs text-muted-foreground mt-1">
                          days this year
                        </p>
                      </div>

                      {Object.entries(leaveByType).map(([type, data]) => (
                        <div
                          key={type}
                          className="p-4 rounded-xl bg-background/50 border border-border/50"
                        >
                          <p className="text-sm text-muted-foreground mb-1 capitalize">
                            {type.toLowerCase().replace("_", " ")}
                          </p>
                          <p className="text-2xl font-bold">{data.days}</p>
