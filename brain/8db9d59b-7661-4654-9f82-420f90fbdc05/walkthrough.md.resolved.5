  };

  // CSV Export Functions
  const formatDate = (dateString: string) => {
    return new Date(dateString).toLocaleDateString("en-CA"); // YYYY-MM-DD format
  };

  const formatStatus = (status: string) => {
    const statusMap: Record<string, string> = {
      PENDING_OM: "Pending OM Approval",
      PENDING_GM: "Pending General Manager Approval",
      APPROVED: "Approved",
      REJECTED_OM: "Rejected by OM",
      REJECTED_GM: "Rejected by General Manager",
    };
    return statusMap[status] || status;
  };

  const escapeCSV = (value: string | undefined | null): string => {
    if (value === undefined || value === null) return "";
    const str = String(value);
    // If the value contains comma, newline, or double quote, wrap in quotes and escape quotes
    if (str.includes(",") || str.includes("\n") || str.includes('"')) {
      return `"${str.replace(/"/g, '""')}"`;
    }
    return str;
  };

  const generateCSV = (requestsToExport: LeaveRequest[]): string => {
    const headers = [
      "Employee Name",
      "Position",
      "Leave Type",
      "Start Date",
      "End Date",
      "Is Scattered",
      "Scattered Dates",
      "Days",
      "Status",
      "Submitted Date",
      "OM Approval Date",
      "GM Approval Date",
      "Rejection Reason",
      "Reason/Description",
    ];

    const rows = requestsToExport.map((req) => [
      escapeCSV(req.employeeName),
      escapeCSV(req.employeePosition),
      escapeCSV(req.leaveType),
      formatDate(req.startDate),
      formatDate(req.endDate),
      req.isScattered ? "Yes" : "No",
      req.isScattered && req.scatteredDates
        ? escapeCSV(req.scatteredDates.join(", "))
        : "",
      String(req.days),
      formatStatus(req.status),
      formatDate(req.submittedDate),
      req.omApprovalDate ? formatDate(req.omApprovalDate) : "",
      req.gmApprovalDate ? formatDate(req.gmApprovalDate) : "",
      escapeCSV(req.rejectionReason),
      escapeCSV(req.reason),
    ]);

    return [headers.join(","), ...rows.map((row) => row.join(","))].join("\n");
  };

  const downloadCSV = (csvContent: string, filename: string) => {
    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const link = document.createElement("a");
    const url = URL.createObjectURL(blob);
    link.setAttribute("href", url);
    link.setAttribute("download", filename);
    link.style.visibility = "hidden";
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  };

  const handleExportAll = () => {
    if (filteredRequests.length === 0) {
      toast({
        variant: "destructive",
        title: "No Data",
        description: "No leave requests to export",
      });
      return;
    }
    const csv = generateCSV(filteredRequests);
    const timestamp = new Date().toISOString().split("T")[0];
    downloadCSV(csv, `leave-requests-${timestamp}.csv`);
    toast({
      title: "Success",
      description: `Exported ${filteredRequests.length} leave request(s)`,
    });
  };

  const handleExportSelected = () => {
    const selectedList = filteredRequests.filter((req) =>
      selectedRequests.has(req.id),
    );
    if (selectedList.length === 0) {
      toast({
        variant: "destructive",
        title: "No Selection",
        description: "No requests selected for export",
      });
      return;
    }
    const csv = generateCSV(selectedList);
    const timestamp = new Date().toISOString().split("T")[0];
    downloadCSV(csv, `leave-requests-selected-${timestamp}.csv`);
    toast({
      title: "Success",
      description: `Exported ${selectedList.length} selected request(s)`,
