                  )}
                  {leaveType === "PATERNITY" && user?.employee?.gender !== "MALE" && (
                    <div className="text-[10px] text-red-500 font-medium mt-1 flex items-center gap-1 px-1">
                      <XCircle className="h-3 w-3" />
