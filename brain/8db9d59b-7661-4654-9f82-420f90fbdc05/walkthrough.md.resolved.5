    },
    onSuccess: () => {
      toast({
        title: "Success",
        description: "Request finally approved by CEO",
      });
    },
  });

  const reject = useMutation({
    mutationFn: ({ id, reason }: { id: string; reason: string }) =>
      api.post(`/leave-requests/${id}/reject`, { reason }),
    onMutate: async ({ id, reason }) => {
      await queryClient.cancelQueries({
        queryKey: ["leaveRequests", currentPage, itemsPerPage],
      });
      const previousData = queryClient.getQueryData([
        "leaveRequests",
        currentPage,
        itemsPerPage,
      ]);

      queryClient.setQueryData(
        ["leaveRequests", currentPage, itemsPerPage],
        (
          old:
            | { success: boolean; data: { leaveRequests: LeaveRequest[] } }
            | undefined,
        ) => {
          if (!old) return old;
          return {
            ...old,
            data: {
              ...old.data,
              leaveRequests: old.data.leaveRequests.map((req: LeaveRequest) => {
                if (req.id === id) {
                  let newStatus: LeaveRequest["status"] = "REJECTED_OM";
                  if (req.status === "PENDING_GM") newStatus = "REJECTED_GM";
                  if (req.status === "PENDING_CEO") newStatus = "REJECTED_CEO";
                  return {
                    ...req,
                    status: newStatus,
                    rejectionReason: reason,
                    rejectedAt: new Date().toISOString(),
                  };
                }
                return req;
              }),
            },
          };
        },
      );

      return { previousData };
    },
    onError: (err: unknown, variables, context) => {
      const error = err as { response?: { data?: { message?: string } } };
      queryClient.setQueryData(
        ["leaveRequests", currentPage, itemsPerPage],
        context?.previousData,
      );
      toast({
        variant: "destructive",
        title: "Error",
        description: error.response?.data?.message || "Failed to reject",
      });
    },
    onSettled: () => {
      queryClient.invalidateQueries({ queryKey: ["leaveRequests"] });
    },
    onSuccess: () => {
      toast({ title: "Success", description: "Request rejected" });
    },
  });

  // Bulk selection handlers
  const handleSelectRequest = (id: string) => {
    const newSelected = new Set(selectedRequests);
    if (newSelected.has(id)) {
      newSelected.delete(id);
    } else {
      newSelected.add(id);
    }
    setSelectedRequests(newSelected);
  };

  const handleSelectAll = () => {
    if (
      selectedRequests.size === filteredRequests.length &&
      filteredRequests.length > 0
    ) {
      setSelectedRequests(new Set());
    } else {
      setSelectedRequests(new Set(filteredRequests.map((req) => req.id)));
    }
  };

  // Bulk actions
  const bulkApprove = useMutation({
    mutationFn: async (ids: string[]) => {
      return Promise.all(
        ids.map((id) =>
          api.post(`/leave-requests/${id}/om-approve`, { comments: "" }),
        ),
      );
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ["leaveRequests"] });
      const count = selectedRequests.size;
      setSelectedRequests(new Set());
      toast({ title: "Success", description: `${count} request(s) approved` });
    },
    onError: (error: unknown) => {
      const err = error as { response?: { data?: { message?: string } } };
      toast({
        variant: "destructive",
        title: "Error",
        description:
          err.response?.data?.message || "Failed to approve requests",
      });
    },
  });

  const bulkReject = useMutation({
    mutationFn: async ({ ids, reason }: { ids: string[]; reason: string }) => {
      return Promise.all(
        ids.map((id) => api.post(`/leave-requests/${id}/reject`, { reason })),
      );
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ["leaveRequests"] });
      const count = selectedRequests.size;
      setSelectedRequests(new Set());
      toast({ title: "Success", description: `${count} request(s) rejected` });
    },
    onError: (error: unknown) => {
      const err = error as { response?: { data?: { message?: string } } };
      toast({
        variant: "destructive",
        title: "Error",
        description: err.response?.data?.message || "Failed to reject requests",
      });
    },
  });

  // Fetch employees for the employee filter dropdown
  const { data: employeesData } = useQuery({
    queryKey: ["employees"],
    queryFn: async ({ signal }) => {
      const response = await api.get("/employees", { signal });
      return response.data.data.employees || [];
    },
    // Note: query runs for all users — managers need it for employee filtering,
    // all users need it for handover Line Manager / CC dropdowns.
  });

  // Reuse employees query data for Line Manager / CC dropdowns (avoid duplicate API call)
  const allEmployeesData = employeesData;

  interface DeptEmployee {
    id: string;
    department: string;
    position: string;
    user?: { id: string; name: string };
    name?: string;
  }

  const departmentColleagues: DeptEmployee[] = (allEmployeesData || []).filter(
    (emp: DeptEmployee) =>
      emp.department?.toUpperCase() ===
        user?.employee?.department?.toUpperCase() && emp.user?.id !== user?.id,
  );

  const allColleagues: DeptEmployee[] = (allEmployeesData || []).filter(
    (emp: DeptEmployee) => emp.user?.id !== user?.id,
  );

  const handoverOptions =
    departmentColleagues.length > 0 ? departmentColleagues : allColleagues;

  const { data: paginatedData, isLoading } = useQuery({
    queryKey: ["leaveRequests", currentPage, itemsPerPage, user?.role],
    queryFn: async ({ signal }) => {
      // Non-executives use /my-leaves endpoint, while OM, GM, and CEO use /leave-requests
      const isExecutive = [
        "OPERATIONS_MANAGER",
        "GENERAL_MANAGER",
        "CEO",
      ].includes(user?.role || "");
      const endpoint = isExecutive
        ? "/leave-requests"
        : "/leave-requests/my-leaves";

      const response = await api.get(endpoint, {
        params: isExecutive ? { page: currentPage, limit: itemsPerPage } : {},
        signal, // Pass signal for automatic cancellation
      });
      return response.data;
    },
    enabled: !!user, // Only run query when user is available
  });

  const requests: LeaveRequest[] = useMemo(
    () =>
      paginatedData?.data?.leaveRequests?.map(
        (req: Record<string, unknown>) => ({
          id: req.id as string,
          requestNumber: req.requestNumber as number,
          employeeId: req.employeeId as string,
          employeeName: (req.employee as { user: { name: string } }).user
            .name as string,
          employeePosition: (req.employee as { position: string })
            .position as string,
          employeeAvatar: `https://api.dicebear.com/7.x/initials/svg?seed=${(req.employee as { user: { name: string } }).user.name}&backgroundColor=08033F`,
          leaveType: req.leaveType as LeaveType,
          startDate: req.startDate as string,
          endDate: req.endDate as string,
          days: (() => {
            const ws = "MON_FRI"; // fallback; actual schedule not available here
            const start = (req.startDate as string).split("T")[0];
            const end = (req.endDate as string).split("T")[0];
            if (req.isScattered && req.scatteredDates) {
              // scatteredDates may arrive as a JSON string from the API
              let datesArr: string[] = [];
              if (typeof req.scatteredDates === "string") {
                try { datesArr = JSON.parse(req.scatteredDates as string); } catch { datesArr = []; }
              } else {
                datesArr = req.scatteredDates as string[];
              }
              return datesArr.length;
            }
            return calculateLeaveDays(start, end, ws);
          })(),
          reason: req.description as string,
          status: req.status as LeaveRequest["status"],
          submittedDate: req.createdAt as string,

          // Scattered leave
          isScattered: (req.isScattered as boolean) || false,
          scatteredDates: (() => {
            if (!req.scatteredDates) return [];
            if (typeof req.scatteredDates === "string") {
              try { return JSON.parse(req.scatteredDates as string) as string[]; } catch { return []; }
            }
            return req.scatteredDates as string[];
          })(),

          // Approval details
          omApprover: req.omApprover as
            | { name: string; email: string }
            | undefined,
          omApprovalDate: req.omApprovalDate as string,
          omApprovalComments: req.omApprovalComments as string,
          gmApprover: req.gmApprover as
            | { name: string; email: string }
            | undefined,
          gmApprovalDate: req.gmApprovalDate as string,
          gmApprovalComments: req.gmApprovalComments as string,
          rejectedBy: req.rejectedBy as string,
          rejectedAt: req.rejectedAt as string,
          rejectionReason: req.rejectionReason as string,

          contactWhileOnLeave: req.contactWhileOnLeave as string,
          handoverLineManager: req.handoverLineManager as string,
