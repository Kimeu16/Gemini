  // Advanced filtering logic
  const filteredRequests = requests.filter((req: LeaveRequest) => {
    // Status filter
    if (statusFilter !== "all" && req.status !== statusFilter) return false;

    // Search by employee name
    if (
      searchQuery &&
      !req.employeeName.toLowerCase().includes(searchQuery.toLowerCase())
    )
      return false;

    // Leave type filter
    if (leaveTypeFilter !== "all" && req.leaveType !== leaveTypeFilter)
      return false;

    // Employee filter
    if (employeeFilter !== "all" && req.employeeId !== employeeFilter)
      return false;

    // Date range filter
    if (dateFrom && new Date(req.startDate) < new Date(dateFrom)) return false;
    if (dateTo && new Date(req.endDate) > new Date(dateTo)) return false;

    return true;
  });

