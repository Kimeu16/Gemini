                    >
                      <XCircle className="h-4 w-4 mr-1" />
                      {bulkReject.isPending
                        ? "Rejecting..."
                        : "Reject Selected"}
                    </Button>
                  )}
                  <Button
                    size="sm"
                    variant="outline"
                    onClick={handleExportSelected}
                    className="gap-1 border-border/50"
                  >
                    <FileSpreadsheet className="h-4 w-4" />
                    Export Selected
                  </Button>
                </div>
              </div>
            </Card>
          </motion.div>
        )}

        <motion.div
