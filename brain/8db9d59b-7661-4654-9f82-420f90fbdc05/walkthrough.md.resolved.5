                        pageNum = i + 1;
                      } else if (currentPage >= paginatedData.totalPages - 2) {
                        pageNum = paginatedData.totalPages - 4 + i;
                      } else {
                        pageNum = currentPage - 2 + i;
                      }
                      return (
                        <Button
                          key={pageNum}
                          variant={
                            currentPage === pageNum ? "default" : "outline"
                          }
                          size="sm"
                          onClick={() => setCurrentPage(pageNum)}
                          className="w-10"
                        >
                          {pageNum}
                        </Button>
                      );
                    },
                  )}
                </div>
                <Button
                  variant="outline"
                  size="sm"
                  onClick={() =>
                    setCurrentPage((prev) =>
                      Math.min(paginatedData.totalPages, prev + 1),
                    )
                  }
                  disabled={!paginatedData.hasNextPage || isLoading}
